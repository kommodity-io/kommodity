{
    "schemes": [
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "API endpoints for Kommodity UI.",
        "title": "Kommodity UI API",
        "contact": {},
        "version": "0.1.0"
    },
    "basePath": "/",
    "paths": {
        "/api/cluster/{clusterName}/health": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "UI",
                    "Info",
                    "Health"
                ],
                "summary": "Checks the health of a cluster by accessing its /livez endpoint",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Name of the cluster to check health for",
                        "name": "clusterName",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.ClusterHealthResponse"
                        }
                    },
                    "400": {
                        "description": "If the cluster name is missing or invalid",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "If there is a server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/clusters": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Clusters"
                ],
                "summary": "List all clusters with their chart versions",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.ClusterAPIResponse"
                        }
                    },
                    "500": {
                        "description": "If there is a server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/info": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "UI",
                    "Info"
                ],
                "summary": "Obtain Kommodity system information",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "If there is a server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.ChartInfo": {
            "type": "object",
            "properties": {
                "version": {
                    "type": "string"
                }
            }
        },
        "api.ClusterAPIItem": {
            "type": "object",
            "properties": {
                "chart": {
                    "$ref": "#/definitions/api.ChartInfo"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "api.ClusterAPIResponse": {
            "type": "object",
            "properties": {
                "clusters": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/api.ClusterAPIItem"
                    }
                }
            }
        },
        "api.ClusterHealthResponse": {
            "type": "object",
            "properties": {
                "healthy": {
                    "type": "boolean"
                },
                "reason": {
                    "type": "string"
                }
            }
        }
    }
}